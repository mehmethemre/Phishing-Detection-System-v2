<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Phishing Detective — Şüpheli Metin Analiz Sistemi</title>
    <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --green:    #00ff88;
            --green-dim:#00cc66;
            --red:      #ff2d55;
            --cyan:     #00e5ff;
            --yellow:   #ffe600;
            --bg:       #050e0a;
            --panel:    #0a1a11;
            --border:   #1a3a24;
            --mono:     'Share Tech Mono', monospace;
            --display:  'Orbitron', monospace;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        html, body {
            height: 100%;
            background: var(--bg);
            color: var(--green);
            font-family: var(--mono);
            overflow-x: hidden;
        }

        /* ── MATRIX RAIN CANVAS ── */
        #matrix-canvas {
            position: fixed;
            inset: 0;
            z-index: 0;
            opacity: .18;
        }

        /* ── SCANLINE OVERLAY ── */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            z-index: 1;
            background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 2px,
                rgba(0,0,0,.08) 2px,
                rgba(0,0,0,.08) 4px
            );
            pointer-events: none;
        }

        /* ── GRAIN ── */
        body::after {
            content: '';
            position: fixed;
            inset: -50%;
            z-index: 2;
            width: 200%; height: 200%;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
            opacity: .03;
            pointer-events: none;
            animation: grain 8s steps(10) infinite;
        }
        @@keyframes grain {
            0%,100%{ transform: translate(0,0) }
            10%     { transform: translate(-2%,-3%) }
            20%     { transform: translate(3%, 1%) }
            30%     { transform: translate(-1%, 4%) }
            40%     { transform: translate(4%,-2%) }
            50%     { transform: translate(-3%, 3%) }
            60%     { transform: translate(2%, 2%) }
            70%     { transform: translate(-4%,-1%) }
            80%     { transform: translate(1%,-4%) }
            90%     { transform: translate(-2%, 2%) }
        }

        /* ── PAGE LAYOUT ── */
        .page-wrapper {
            position: relative;
            z-index: 10;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 16px 60px;
        }

        /* ── TOP STATUS BAR ── */
        .status-bar {
            width: 100%;
            max-width: 900px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: .7rem;
            letter-spacing: .1em;
            color: var(--green-dim);
            border-bottom: 1px solid var(--border);
            padding-bottom: 10px;
            margin-bottom: 40px;
        }
        .status-dot {
            display: inline-block;
            width: 7px; height: 7px;
            border-radius: 50%;
            background: var(--green);
            box-shadow: 0 0 8px var(--green);
            margin-right: 6px;
            animation: blink 1.4s infinite;
        }
        @@keyframes blink { 50% { opacity: .2 } }

        /* ── HEADER ── */
        .header-block {
            text-align: center;
            margin-bottom: 48px;
        }
        .header-eyebrow {
            font-family: var(--mono);
            font-size: .72rem;
            letter-spacing: .3em;
            color: var(--cyan);
            text-transform: uppercase;
            margin-bottom: 14px;
        }
        .header-title {
            font-family: var(--display);
            font-size: clamp(1.8rem, 5vw, 3.2rem);
            font-weight: 900;
            letter-spacing: .06em;
            line-height: 1.1;
            color: #fff;
            text-shadow:
                0 0 18px var(--green),
                0 0 40px rgba(0,255,136,.3);
            position: relative;
        }
        .header-title .accent { color: var(--green); }
        .header-title::after {
            content: attr(data-text);
            position: absolute;
            inset: 0;
            clip-path: polygon(0 0, 100% 0, 100% 45%, 0 45%);
            transform: translateX(2px);
            color: var(--cyan);
            opacity: 0;
            animation: glitch 6s infinite;
        }
        @@keyframes glitch {
            0%,94%,100% { opacity:0; transform:translateX(2px) }
            95% { opacity:.7; transform:translateX(-3px) skewX(-5deg) }
            97% { opacity:.5; transform:translateX(4px) }
            99% { opacity:.6; transform:translateX(-2px) }
        }
        .header-sub {
            margin-top: 12px;
            font-size: .8rem;
            color: #3a7a55;
            letter-spacing: .1em;
        }

        /* ── SHIELD ICON ── */
        .shield-wrapper {
            display: flex;
            justify-content: center;
            margin-bottom: 32px;
        }
        .shield-svg {
            filter: drop-shadow(0 0 16px var(--green)) drop-shadow(0 0 40px rgba(0,255,136,.2));
            animation: pulse-shield 3s ease-in-out infinite;
        }
        @@keyframes pulse-shield {
            0%,100% { filter: drop-shadow(0 0 14px var(--green)) drop-shadow(0 0 36px rgba(0,255,136,.2)); }
            50%      { filter: drop-shadow(0 0 26px var(--green)) drop-shadow(0 0 60px rgba(0,255,136,.4)); }
        }

        /* ── THREAT INDICATORS ── */
        .threat-row {
            width: 100%;
            max-width: 900px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 12px;
            margin-bottom: 36px;
        }
        .threat-card {
            background: var(--panel);
            border: 1px solid var(--border);
            border-top: 2px solid var(--green);
            padding: 14px 18px;
            position: relative;
            overflow: hidden;
        }
        .threat-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: linear-gradient(135deg, rgba(0,255,136,.04) 0%, transparent 60%);
            pointer-events: none;
        }
        .tc-label {
            font-size: .62rem;
            letter-spacing: .2em;
            color: #3a7a55;
            text-transform: uppercase;
            margin-bottom: 4px;
        }
        .tc-value {
            font-family: var(--display);
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--green);
        }
        .tc-value.red   { color: var(--red);    text-shadow: 0 0 12px var(--red); }
        .tc-value.cyan  { color: var(--cyan);   text-shadow: 0 0 12px var(--cyan); }
        .tc-value.yellow{ color: var(--yellow); text-shadow: 0 0 12px var(--yellow); }

        /* ── MAIN PANEL ── */
        .main-panel {
            width: 100%;
            max-width: 900px;
            background: var(--panel);
            border: 1px solid var(--border);
            position: relative;
        }

        /* corner brackets */
        .main-panel::before,
        .main-panel::after {
            content: '';
            position: absolute;
            width: 18px; height: 18px;
        }
        .main-panel::before {
            top: -1px; left: -1px;
            border-top: 2px solid var(--green);
            border-left: 2px solid var(--green);
        }
        .main-panel::after {
            bottom: -1px; right: -1px;
            border-bottom: 2px solid var(--green);
            border-right: 2px solid var(--green);
        }

        .panel-header {
            background: #071209;
            border-bottom: 1px solid var(--border);
            padding: 14px 24px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .panel-dot {
            width: 10px; height: 10px;
            border-radius: 50%;
        }
        .panel-dot.g { background: var(--green); box-shadow: 0 0 6px var(--green); }
        .panel-dot.y { background: var(--yellow); }
        .panel-dot.r { background: var(--red); }
        .panel-title {
            margin-left: 8px;
            font-size: .72rem;
            letter-spacing: .2em;
            color: var(--green-dim);
            text-transform: uppercase;
        }

        .panel-body { padding: 32px; }

        /* ── FORM ── */
        .input-label {
            font-size: .68rem;
            letter-spacing: .18em;
            color: var(--cyan);
            text-transform: uppercase;
            margin-bottom: 10px;
            display: block;
        }
        .input-label .prompt { color: var(--green); margin-right: 6px; }

        .threat-textarea {
            width: 100%;
            background: #030a06;
            border: 1px solid #1a3a24;
            border-left: 3px solid var(--green);
            color: var(--green);
            font-family: var(--mono);
            font-size: .9rem;
            line-height: 1.7;
            padding: 16px 20px;
            resize: vertical;
            min-height: 160px;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
        }
        .threat-textarea::placeholder { color: #1e5c33; }
        .threat-textarea:focus {
            border-color: var(--green);
            box-shadow: 0 0 0 1px var(--green), inset 0 0 20px rgba(0,255,136,.04);
        }

        /* ── OPTIONS ROW ── */
        .options-row {
            display: flex;
            gap: 12px;
            margin-top: 16px;
            flex-wrap: wrap;
        }
        .opt-tag {
            font-size: .65rem;
            letter-spacing: .15em;
            color: #3a7a55;
            border: 1px solid var(--border);
            padding: 5px 12px;
            cursor: pointer;
            transition: all .15s;
            user-select: none;
        }
        .opt-tag:hover, .opt-tag.active {
            background: rgba(0,255,136,.08);
            border-color: var(--green);
            color: var(--green);
        }

        /* ── SUBMIT BUTTON ── */
        .analyze-btn {
            margin-top: 28px;
            width: 100%;
            background: transparent;
            border: 1px solid var(--green);
            color: var(--green);
            font-family: var(--display);
            font-size: .85rem;
            font-weight: 700;
            letter-spacing: .25em;
            text-transform: uppercase;
            padding: 16px 32px;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: color .25s;
        }
        .analyze-btn::before {
            content: '';
            position: absolute;
            inset: 0;
            background: var(--green);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform .3s cubic-bezier(.4,0,.2,1);
            z-index: 0;
        }
        .analyze-btn:hover::before  { transform: scaleX(1); }
        .analyze-btn:hover { color: #000; }
        .analyze-btn span { position: relative; z-index: 1; }

        .analyze-btn:active { transform: scaleY(.97); }

        /* ── DIVIDER ── */
        .section-divider {
            border: none;
            border-top: 1px solid var(--border);
            margin: 32px 0;
            position: relative;
        }
        .section-divider::before {
            content: '// SONUÇ';
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            background: var(--panel);
            padding: 0 14px;
            font-size: .62rem;
            letter-spacing: .25em;
            color: #2a5c3a;
        }

        /* ── RESULT AREA ── */
        .result-box {
            background: #030a06;
            border: 1px solid var(--border);
            border-left: 3px solid var(--red);
            padding: 20px 24px;
            min-height: 70px;
            display: flex;
            align-items: flex-start;
            gap: 14px;
            position: relative;
        }
        .result-icon {
            font-size: 1.4rem;
            flex-shrink: 0;
            margin-top: 2px;
        }
        .result-text {
            font-size: .92rem;
            line-height: 1.6;
            color: #ff6b80;
            font-family: var(--mono);
            word-break: break-word;
        }
        .result-text.empty { color: #2a5c3a; font-style: italic; }

        /* ── LIVE LOG ── */
        .live-log {
            margin-top: 28px;
            background: #030a06;
            border: 1px solid var(--border);
            padding: 16px 20px;
            height: 110px;
            overflow-y: auto;
            font-size: .72rem;
            line-height: 1.9;
            color: #2a5c3a;
        }
        .live-log .log-line { animation: fadein .3s ease; }
        .live-log .log-line .ts { color: #1a3a24; margin-right: 10px; }
        .live-log .log-line .msg { color: #3a7a55; }
        .live-log .log-line .msg.warn { color: var(--yellow); }
        .live-log .log-line .msg.ok   { color: var(--green); }
        .live-log .log-line .msg.err  { color: var(--red); }
        @@keyframes fadein { from { opacity:0; transform:translateY(4px) } to { opacity:1; transform:none } }

        /* ── FOOTER ── */
        .footer {
            margin-top: 48px;
            text-align: center;
            font-size: .65rem;
            letter-spacing: .15em;
            color: #1a3a24;
        }
        .footer a { color: #2a5c3a; text-decoration: none; }
        .footer a:hover { color: var(--green); }

        /* ── SCROLLBAR ── */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: #1a3a24; }
        ::-webkit-scrollbar-thumb:hover { background: var(--green); }

        /* ── RESPONSIVE ── */
        @@media (max-width: 576px) {
            .panel-body { padding: 20px 16px; }
            .threat-row { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
<body>

<!-- Matrix Rain -->
<canvas id="matrix-canvas"></canvas>

<div class="page-wrapper">

    <!-- Status Bar -->
    <div class="status-bar">
        <span><span class="status-dot"></span>SİSTEM AKTİF — v2.4.1</span>
        <span id="clock">——</span>
        <span>BAĞLANTI: <span style="color:var(--green)">ŞİFRELİ TLS 1.3</span></span>
    </div>

    <!-- Header -->
    <div class="header-block">
        <div class="header-eyebrow">// siber güvenlik analiz modülü //</div>

        <div class="shield-wrapper">
            <svg class="shield-svg" width="64" height="72" viewBox="0 0 64 72" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M32 2L6 14V36C6 50.5 17.6 64 32 68C46.4 64 58 50.5 58 36V14L32 2Z" stroke="#00ff88" stroke-width="1.5" fill="rgba(0,255,136,0.05)"/>
                <path d="M32 14L18 20V34C18 43 24.8 51.4 32 54C39.2 51.4 46 43 46 34V20L32 14Z" stroke="#00ff88" stroke-width="1" fill="rgba(0,255,136,0.08)" stroke-dasharray="4 2"/>
                <circle cx="32" cy="34" r="6" stroke="#00ff88" stroke-width="1.5" fill="rgba(0,255,136,0.15)"/>
                <circle cx="32" cy="34" r="2" fill="#00ff88"/>
                <line x1="32" y1="14" x2="32" y2="22" stroke="#00ff88" stroke-width="1"/>
                <line x1="32" y1="46" x2="32" y2="54" stroke="#00ff88" stroke-width="1"/>
                <line x1="18" y1="34" x2="26" y2="34" stroke="#00ff88" stroke-width="1"/>
                <line x1="38" y1="34" x2="46" y2="34" stroke="#00ff88" stroke-width="1"/>
            </svg>
        </div>

        <h1 class="header-title" data-text="PHİSHİNG DETECTİVE">
            PHİSHİNG <span class="accent">DETECTİVE</span>
        </h1>
        <p class="header-sub">// yapay zeka destekli tehdit analiz sistemi //</p>
    </div>

    <!-- Threat Indicator Cards -->
    <div class="threat-row">
        <div class="threat-card">
            <div class="tc-label">Toplam Tarama</div>
            <div class="tc-value cyan" id="scan-count">8.412</div>
        </div>
        <div class="threat-card">
            <div class="tc-label">Tespit Edilen</div>
            <div class="tc-value red" id="detected-count">1.203</div>
        </div>
        <div class="threat-card">
            <div class="tc-label">Başarı Oranı</div>
            <div class="tc-value">97.8%</div>
        </div>
        <div class="threat-card">
            <div class="tc-label">Model Sürümü</div>
            <div class="tc-value yellow">GPT-PD/3</div>
        </div>
        <div class="threat-card">
            <div class="tc-label">Tehdit Seviyesi</div>
            <div class="tc-value red" id="threat-level">YÜKSEK</div>
        </div>
    </div>

    <!-- Main Analysis Panel -->
    <div class="main-panel">
        <div class="panel-header">
            <div class="panel-dot r"></div>
            <div class="panel-dot y"></div>
            <div class="panel-dot g"></div>
            <span class="panel-title">analiz_konsolu — şüpheli_içerik.txt</span>
        </div>

        <div class="panel-body">

            <!-- ASP.NET Core Razor form — action ve method korundu -->
            <form method="post" action="/Document/AnalyzeText" id="analyze-form">

                <label class="input-label">
                    <span class="prompt">$</span>ŞÜPHELİ METİN GİRİŞİ
                </label>

                <textarea
                    class="threat-textarea"
                    name="text"
                    id="threat-input"
                    rows="6"
                    placeholder="// Şüpheli e-posta veya mesaj içeriğini buraya yapıştırın...
// Desteklenen formatlar: düz metin, e-posta başlıkları, SMS, URL"
                    required></textarea>

                <!-- Analiz seçenekleri (opsiyonel tag'ler) -->
                <div class="options-row">
                    <div class="opt-tag active" data-type="email">E-POSTA</div>
                    <div class="opt-tag" data-type="sms">SMS</div>
                    <div class="opt-tag" data-type="url">URL</div>
                    <div class="opt-tag" data-type="social">SOSYAL MEDYA</div>
                    <div class="opt-tag" data-type="other">DİĞER</div>
                </div>
                <input type="hidden" name="contentType" id="content-type-input" value="email">

                <button type="submit" class="analyze-btn" id="submit-btn">
                    <span>⟶ &nbsp; ANALİZİ BAŞLAT</span>
                </button>

            </form>

            <!-- Divider -->
            <hr class="section-divider">

            <!-- Result Box — @ViewBag.Result buraya render edilir -->
            <div class="result-box" id="result-box">
                <div class="result-icon">⚠</div>
                <div class="result-text @(ViewBag.Result == null ? "empty" : "")" id="result-text">
                    @if (ViewBag.Result != null)
                    {
                        @ViewBag.Result
                    }
                    else
                    {
                        <text>// Henüz analiz yapılmadı. Metin girin ve "Analizi Başlat"a tıklayın.</text>
                    }
                </div>
            </div>

            <!-- Live Activity Log -->
            <div class="live-log" id="live-log">
                <div class="log-line"><span class="ts">[SYS]</span><span class="msg ok">Sistem başlatıldı — tüm modüller aktif.</span></div>
                <div class="log-line"><span class="ts">[INF]</span><span class="msg">NLP motoru hazır. Bağlantı: api.phish-detect.ai:443</span></div>
                <div class="log-line"><span class="ts">[INF]</span><span class="msg">Tehdit veritabanı güncellendi — 2.1M imza yüklendi.</span></div>
                <div class="log-line"><span class="ts">[SEC]</span><span class="msg warn">Bekleyen analiz: 0 — Sonraki tarama bekleniyor.</span></div>
            </div>

        </div>
    </div>

    <!-- Footer -->
    <div class="footer">
        <p>PHİSHİNG DETECTİVE &copy; 2025 &nbsp;|&nbsp; Şifreli bağlantı aktif &nbsp;|&nbsp;
        <a href="#">Gizlilik Politikası</a> &nbsp;|&nbsp; <a href="#">Destek</a></p>
        <p style="margin-top:6px; color:#0e2a18">// Tüm veriler yerel olarak işlenir. Hiçbir içerik üçüncü taraflarla paylaşılmaz. //</p>
    </div>

</div><!-- /page-wrapper -->

<script>
/* ─────────────────────────────────────────────
   1. MATRIX RAIN
───────────────────────────────────────────── */
(function() {
    const canvas = document.getElementById('matrix-canvas');
    const ctx = canvas.getContext('2d');
    const chars = 'アカサタナハマヤラワイキシチニヒミリゐウクスツヌフムユルヲエケセテネヘメレヱオコソトノホモヨロヲABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789<>/\\|{}[]01';
    const fontSize = 13;
    let columns, drops;

    function resize() {
        canvas.width  = window.innerWidth;
        canvas.height = window.innerHeight;
        columns = Math.floor(canvas.width / fontSize);
        drops = Array(columns).fill(1);
    }

    function draw() {
        ctx.fillStyle = 'rgba(5,14,10,0.05)';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = '#00ff88';
        ctx.font = fontSize + 'px Share Tech Mono';
        for (let i = 0; i < drops.length; i++) {
            const ch = chars[Math.floor(Math.random() * chars.length)];
            ctx.globalAlpha = Math.random() * .5 + .2;
            ctx.fillText(ch, i * fontSize, drops[i] * fontSize);
            ctx.globalAlpha = 1;
            if (drops[i] * fontSize > canvas.height && Math.random() > .975) drops[i] = 0;
            drops[i]++;
        }
    }

    resize();
    window.addEventListener('resize', resize);
    setInterval(draw, 45);
})();

/* ─────────────────────────────────────────────
   2. CLOCK
───────────────────────────────────────────── */
function updateClock() {
    const now = new Date();
    document.getElementById('clock').textContent =
        now.toLocaleTimeString('tr-TR', { hour12: false }) +
        ' — ' + now.toLocaleDateString('tr-TR');
}
updateClock();
setInterval(updateClock, 1000);

/* ─────────────────────────────────────────────
   3. OPTION TAGS
───────────────────────────────────────────── */
document.querySelectorAll('.opt-tag').forEach(tag => {
    tag.addEventListener('click', () => {
        document.querySelectorAll('.opt-tag').forEach(t => t.classList.remove('active'));
        tag.classList.add('active');
        document.getElementById('content-type-input').value = tag.dataset.type;
    });
});

/* ─────────────────────────────────────────────
   4. LIVE LOG
───────────────────────────────────────────── */
const log = document.getElementById('live-log');
const logMessages = [
    { cls: 'ok',   text: 'Güvenlik duvarı kontrolü tamamlandı.' },
    { cls: '',     text: 'IP bağlantısı şifreli kanal üzerinden doğrulandı.' },
    { cls: 'warn', text: 'Şüpheli URL örüntüsü veritabanında aranıyor...' },
    { cls: '',     text: 'DKIM / SPF kayıt analizi başlatıldı.' },
    { cls: 'ok',   text: 'Model güncellemesi alındı — v3.1.7.' },
    { cls: 'warn', text: 'Yüksek entropi içerik algılandı. İnceleniyor...' },
    { cls: '',     text: 'Gönderici kimliği çapraz referanslanıyor.' },
    { cls: 'err',  text: 'Kara liste eşleşmesi — devam eden doğrulama.' },
    { cls: 'ok',   text: 'NLP semantik analizi tamamlandı.' },
];
let logIdx = 0;

function addLogLine() {
    const item = logMessages[logIdx % logMessages.length];
    const ts = new Date().toLocaleTimeString('tr-TR', { hour12: false });
    const div = document.createElement('div');
    div.className = 'log-line';
    div.innerHTML = `<span class="ts">[${ts}]</span><span class="msg ${item.cls}">${item.text}</span>`;
    log.appendChild(div);
    log.scrollTop = log.scrollHeight;
    logIdx++;
    // Keep max 20 lines
    while (log.children.length > 20) log.removeChild(log.firstChild);
}
setInterval(addLogLine, 3200);

/* ─────────────────────────────────────────────
   5. FORM SUBMIT ANIMATION
───────────────────────────────────────────── */
document.getElementById('analyze-form').addEventListener('submit', function() {
    const btn = document.getElementById('submit-btn');
    btn.innerHTML = '<span>⟳ &nbsp; ANALİZ EDİLİYOR...</span>';
    btn.style.pointerEvents = 'none';
    btn.style.opacity = '.7';

    addLogLine();
    const ts = new Date().toLocaleTimeString('tr-TR', { hour12: false });
    const div = document.createElement('div');
    div.className = 'log-line';
    div.innerHTML = `<span class="ts">[${ts}]</span><span class="msg warn">Kullanıcı girdisi AI motoruna iletiliyor...</span>`;
    log.appendChild(div);
    log.scrollTop = log.scrollHeight;
});

/* ─────────────────────────────────────────────
   6. ANIMATED COUNTERS (once)
───────────────────────────────────────────── */
function animateCounter(el, target, duration) {
    let start = 0;
    const step = target / (duration / 16);
    const timer = setInterval(() => {
        start += step;
        if (start >= target) { el.textContent = target.toLocaleString('tr-TR'); clearInterval(timer); return; }
        el.textContent = Math.floor(start).toLocaleString('tr-TR');
    }, 16);
}
animateCounter(document.getElementById('scan-count'),     8412, 1800);
animateCounter(document.getElementById('detected-count'), 1203, 1800);

/* ─────────────────────────────────────────────
   7. RESULT BOX COLOR LOGIC (Razor ile gelen sonuca göre)
   Sunucu tarafı @ViewBag.Result içeriyorsa renklendirme
───────────────────────────────────────────── */
(function() {
    const resultEl = document.getElementById('result-text');
    const boxEl    = document.getElementById('result-box');
    const text = resultEl ? resultEl.textContent.trim().toLowerCase() : '';

    if (!text || text.startsWith('//')) return; // boş

    // Renklendir
    if (text.includes('phishing') || text.includes('sahte') || text.includes('tehdit') || text.includes('zararlı') || text.includes('uyarı')) {
        boxEl.style.borderLeftColor = 'var(--red)';
        resultEl.style.color = '#ff6b80';
        document.getElementById('result-box').querySelector('.result-icon').textContent = '🚨';
    } else if (text.includes('güvenli') || text.includes('temiz') || text.includes('normal')) {
        boxEl.style.borderLeftColor = 'var(--green)';
        resultEl.style.color = 'var(--green)';
        document.getElementById('result-box').querySelector('.result-icon').textContent = '✔';
    } else {
        boxEl.style.borderLeftColor = 'var(--yellow)';
        resultEl.style.color = 'var(--yellow)';
        document.getElementById('result-box').querySelector('.result-icon').textContent = '⚡';
    }
})();
</script>

